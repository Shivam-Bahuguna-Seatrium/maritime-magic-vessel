# Frontend Application Environment Variables
# Build time variables for Vite - accessible as import.meta.env.VITE_*

# Backend API URL (set this in Vercel environment variables as VITE_API_URL)
# Examples:
#   Development: VITE_API_URL=http://localhost:8000
#   Production: VITE_API_URL=https://maritime-backend-api.vercel.app

VITE_API_URL=http://localhost:8000
