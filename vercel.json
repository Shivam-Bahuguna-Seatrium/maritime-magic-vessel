{
  "buildCommand": "cd maritime_vessel_system/frontend && npm install && npm run build",
  "outputDirectory": "maritime_vessel_system/frontend/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "^/(?!api)[^.]*$",
      "dest": "/index.html"
    }
  ]
}
