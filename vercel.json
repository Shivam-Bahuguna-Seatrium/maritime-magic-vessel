{
  "buildCommand": "cd maritime_vessel_system/frontend && npm install && npm run build",
  "outputDirectory": "maritime_vessel_system/frontend/dist",
  "trailingSlash": false,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "^/(?!api)[^.]*$",
      "dest": "/index.html"
    }
  ]
}
