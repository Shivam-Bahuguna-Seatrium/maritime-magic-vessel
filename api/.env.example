# Backend API Environment Variables
# Copy this to .env and fill in values for your Vercel deployment

# Backend Application
PYTHON_VERSION=3.12

# Neo4j Database Connection (Optional - falls back to in-memory graph if not set)
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# OpenAI API Key (Optional - for advanced conversational features)
OPENAI_API_KEY=sk-your-key-here

# API Server Settings
HOST=0.0.0.0
PORT=8000

# CORS Settings
ALLOWED_ORIGINS=*
