{
  "name": "maritime-vessel-frontend",
  "version": 2,
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "env": {
    "DEPLOYMENT_TYPE": {"value": "frontend"}
  },
  "envTargets": ["production"],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "^/(?!assets)[^.]*$",
      "dest": "/index.html"
    }
  ]
}

