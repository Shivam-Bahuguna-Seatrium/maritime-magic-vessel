# ====================================
# Maritime Vessel System - Backend API
# ====================================
# DEPLOYMENT_TYPE determines how this service is deployed
# Options: "backend" (FastAPI), "frontend" (React), "fullstack" (both)
DEPLOYMENT_TYPE=backend

# Backend Application
PYTHON_VERSION=3.12

# Neo4j Database Connection (Optional - falls back to in-memory graph if not set)
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# OpenAI API Key (Optional - for advanced conversational features)
OPENAI_API_KEY=sk-your-key-here

# API Server Settings
HOST=0.0.0.0
PORT=8000

# CORS Settings
ALLOWED_ORIGINS=*

# Vercel Settings (set in Vercel Project Settings)
# VITE_API_URL should point to this backend when deploying frontend separately
BACKEND_URL=http://localhost:8000
