# ====================================================
# Maritime Vessel System - Frontend React Application
# ====================================================
# DEPLOYMENT_TYPE determines how this service is deployed
# Options: "backend" (FastAPI), "frontend" (React), "fullstack" (both)
DEPLOYMENT_TYPE=frontend

# Backend API URL (set this in Vercel environment variables as VITE_API_URL)
# This is a BUILD-TIME variable that gets baked into the JavaScript bundle
# Must be set BEFORE deployment to Vercel

# Development: Local backend
VITE_API_URL=http://localhost:8000

# Production examples:
#   VITE_API_URL=https://maritime-vessel-api.vercel.app (separate backend project)
#   VITE_API_URL=https://maritime-vessel-system.vercel.app/api (same project backend)
